{
  "name": "@sylingd/qqbot-api",
  "version": "1.0.0",
  "description": "腾讯QQ Bot API Node.js SDK - 完整封装52个API端点，支持ES Module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib build --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "qqbot",
    "tencent",
    "qq",
    "bot",
    "api",
    "sdk",
    "qqbot-api",
    "typescript"
  ],
  "author": "ShuangYa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sylingd/qqbot-api.git"
  },
  "homepage": "",
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@rslib/core": "^0.20.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --files-ignore-unknown=true"
    ]
  }
}
